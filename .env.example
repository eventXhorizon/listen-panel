# Copy to .env and fill in. dev.sh auto-sources this file.
# .env is gitignored.

# YouTube Data API v3 key — enables /news auto-fetch.
# Apply at https://console.cloud.google.com/ → APIs & Services → Credentials.
# Without this, the news fetcher logs a warning and stays idle.
YOUTUBE_API_KEY=

# Optional: override data directory (sqlite + uploads + tts-cache + *.json).
# Default is backend/data. Setting this here is equivalent to the settings page
# "数据存储" field, but takes effect on startup without needing a restart of the
# UI flow.
# LISTEN_PANEL_DATA_DIR=
