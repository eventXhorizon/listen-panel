# Copy to .env on the server and fill in.
# .env is git-ignored.

# ghcr.io image repo prefix. Lowercase of GitHub owner/repo without trailing slash.
IMAGE_REPO=ghcr.io/eventxhorizon

# The tag CI prints at the end of each build. Bump this and run ./deploy.sh
# to roll forward; keep the previous tag in your shell history to roll back.
# Example: 20260523-1430-a1b2c3d
IMAGE_TAG=latest

# Host path where SQLite DB, uploads and TTS cache live. Absolute path.
# Anything in this directory survives container restarts and image upgrades.
DATA_DIR=/root/listen-panel/data

# Port published on the host. Frontend nginx listens here; Cloudflare /
# host-level reverse proxy / direct browser all hit this port.
PUBLISH_PORT=19527

# YouTube Data API v3 key — used by news_fetcher to ingest channel videos.
# Leave blank to disable auto-ingest (existing news_items remain browsable).
YOUTUBE_API_KEY=

# Optional: tracing-subscriber EnvFilter override. Defaults to info.
# RUST_LOG=info,tower_http=debug,sqlx=warn
